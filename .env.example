# ===========================================
# NEXUS Backend - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Application
APP_NAME=NEXUS-Backend
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nexus_db

# Security (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# AI Services
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:nexus-events
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/nexus-queue

# Observability
LOG_LEVEL=INFO

# CORS (comma-separated for multiple origins)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]